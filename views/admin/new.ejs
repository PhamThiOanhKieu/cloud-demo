<!DOCTYPE html>
<html>
<head>

<link
href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
rel="stylesheet">

</head>

<body>

<div class="container-fluid p-5">

<h1>Đăng bài viết</h1>

<form
method="POST"
action="/admin/posts"
enctype="multipart/form-data">

<input
name="title"
class="form-control mb-3"
placeholder="Tiêu đề">

<textarea
name="content"
class="form-control mb-3"
style="height:500px;"
placeholder="Nội dung bài viết">
</textarea>

<input
type="file"
name="image"
class="form-control mb-3">

<button class="btn btn-primary btn-lg">

Đăng bài

</button>

</form>

</div>

</body>
</html>
