<!DOCTYPE html>
<html lang="vi">
<head>

    <meta charset="UTF-8">
    <title><%= course.title %></title>

    <!-- BOOTSTRAP -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- CSS -->
    <link rel="stylesheet" href="/css/style.css">

    <!-- ICON -->
    <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <style>
        .course-hero {
            background: linear-gradient(90deg,#111827,#1f2937);
            color: white;
            padding: 40px;
            border-radius: 16px;
            margin-top: 30px;
        }

        .course-img {
            width: 100%;
            height: 350px;
            object-fit: cover;
            border-radius: 12px;
        }

        .price-box {
            background: white;
            padding: 20px;
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        }

        .price {
            font-size: 28px;
            font-weight: 700;
            color: #e11d48;
        }

        .feature {
            font-size: 14px;
            margin-bottom: 6px;
        }
    </style>

</head>

<body>

<!-- HEADER -->
<%- include("../partials/header") %>

<div class="container">

    <!-- HERO -->
    <div class="course-hero">

        <h1><%= course.title %></h1>

        <p class="mt-3">
            <%= course.description %>
        </p>

        <div class="mt-3">
            <i class="fa fa-star text-warning"></i>
            4.8 (1,200 đánh giá) • 12,500 học viên
        </div>

    </div>

    <!-- MAIN -->
    <div class="row mt-4">

        <!-- LEFT -->
        <div class="col-md-8">

            <img src="<%= course.image %>" class="course-img">

            <h3 class="mt-4">Nội dung khóa học</h3>

            <ul class="mt-3">
                <li>✔ Giới thiệu khóa học</li>
                <li>✔ Kiến thức nền tảng</li>
                <li>✔ Thực hành dự án</li>
                <li>✔ Hoàn thành và cấp chứng chỉ</li>
            </ul>

            <h3 class="mt-5">Video demo</h3>

            <video width="100%" controls class="mt-3">
                <source src="https://www.w3schools.com/html/mov_bbb.mp4">
            </video>

        </div>

        <!-- RIGHT -->
        <div class="col-md-4">

            <div class="price-box">

                <!-- FIX: nếu chưa có price -->
                <div class="price">
                    <%= course.price ? course.price : "499.000" %> VNĐ
                </div>

                <!-- ADD CART -->
                <a href="/add-to-cart/<%= course._id %>"
                   class="btn btn-success w-100 mt-3">
                    🛒 Mua ngay
                </a>

                <!-- VIEW CART -->
                <a href="/cart"
                   class="btn btn-outline-dark w-100 mt-2">
                    Xem giỏ hàng
                </a>

                <hr>

                <div class="feature">✔ Truy cập trọn đời</div>
                <div class="feature">✔ Học mọi lúc mọi nơi</div>
                <div class="feature">✔ Có chứng chỉ</div>
                <div class="feature">✔ Hỗ trợ 24/7</div>

            </div>

        </div>

    </div>

</div>

<!-- FOOTER -->
<%- include("../partials/footer") %>

<!-- FIX: Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
