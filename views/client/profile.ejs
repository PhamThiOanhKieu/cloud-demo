<!DOCTYPE html>
<html lang="vi">

<head>

<meta charset="UTF-8">
<title>Hồ sơ</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="/style.css">

<style>
body{
    background:#f6f7fb;
}

.sidebar{
    background:white;
    border-radius:16px;
    padding:25px;
}

.content{
    background:white;
    border-radius:16px;
    padding:30px;
}

.avatar{
    width:100px;
    height:100px;
    border-radius:50%;
    object-fit:cover;
}
</style>

</head>

<body>

<%- include("../partials/header") %>

<div class="container py-5">

<div class="row">

    <!-- SIDEBAR -->
    <div class="col-md-3">

        <div class="sidebar text-center">

            <img src="https://i.pravatar.cc/200" class="avatar mb-3">

            <h5>
                <%= session.user?.email || "User" %>
            </h5>

            <hr>

            <p><a href="/profile">Hồ sơ</a></p>
            <p><a href="/language">Ngôn ngữ</a></p>
            <p><a href="/support">Hỗ trợ</a></p>
            <p><a href="/logout" class="text-danger">Đăng xuất</a></p>

        </div>

    </div>

    <!-- CONTENT -->
    <div class="col-md-9">

        <div class="content">

            <h3 class="mb-4">Thông tin cá nhân</h3>

            <% if(success){ %>
                <div class="alert alert-success">
                    Cập nhật thành công ✅
                </div>
            <% } %>

            <form action="/profile" method="POST">

                <div class="mb-3">
                    <label>Họ tên</label>
                    <input name="fullname" class="form-control"
                        value="<%= session.user?.fullname || '' %>">
                </div>

                <div class="mb-3">
                    <label>Email</label>
                    <input name="email" class="form-control"
                        value="<%= session.user?.email || '' %>">
                </div>

                <div class="mb-3">
                    <label>Số điện thoại</label>
                    <input name="phone" class="form-control"
                        value="<%= session.user?.phone || '' %>">
                </div>

                <button class="btn btn-primary w-100">
                    Lưu thay đổi
                </button>

            </form>

        </div>

    </div>

</div>

</div>

<%- include("../partials/footer") %>

</body>
</html>
