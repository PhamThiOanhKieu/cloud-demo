<!DOCTYPE html>
<head>
  <title><%= lesson.title %></title>

  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
    rel="stylesheet">
</head>

<body>

<div class="container mt-5">

  <h1><%= lesson.title %></h1>

  <% if(lesson.video){ %>

    <video
      width="100%"
      height="600"
      controls>

      <source src="<%= lesson.video %>">

    </video>

  <% } %>

  <hr>

  <h3>Bình luận</h3>

  <form
    method="POST"
    action="/comment/<%= courseId %>/<%= lessonId %>">

    <textarea
      name="text"
      class="form-control mb-3"></textarea>

    <button class="btn btn-success">
      Gửi bình luận
    </button>

  </form>

  <hr>

  <% comments.forEach(c => { %>

    <div class="alert alert-secondary">
      <%= c.text %>
    </div>

  <% }) %>

</div>

</body>
</html>
