<!DOCTYPE html>
<html>
<head>
  <title>News</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>

<body>

<nav class="navbar navbar-dark bg-dark px-3">
  <span class="navbar-brand">📰 News Portal</span>

  <div>
    <a href="/category/Công nghệ" class="btn btn-outline-light btn-sm">Công nghệ</a>
    <a href="/category/Thể thao" class="btn btn-outline-light btn-sm">Thể thao</a>
    <a href="/category/Giải trí" class="btn btn-outline-light btn-sm">Giải trí</a>
  </div>

  <a href="/new" class="btn btn-success">+ Đăng bài</a>
</nav>

<div class="container mt-4">
  <div class="row">

    <!-- MAIN NEWS -->
    <div class="col-md-8">
      <% posts.forEach((p, i) => { %>
        <div class="card mb-4 shadow">
          <img src="<%= p.image %>" class="card-img-top">
          <div class="card-body">
            <h4><%= p.title %></h4>
            <p><%= p.content.substring(0, 100) %>...</p>
            <a href="/posts/<%= i %>" class="btn btn-primary">Đọc tiếp</a>
          </div>
        </div>
      <% }) %>
    </div>

    <!-- SIDEBAR -->
    <div class="col-md-4">
      <h5>Tin nổi bật</h5>
      <% posts.slice(0,3).forEach((p, i) => { %>
        <div class="mb-3">
          <strong><%= p.title %></strong>
          <hr>
        </div>
      <% }) %>
    </div>

  </div>
</div>

</body>
</html>
