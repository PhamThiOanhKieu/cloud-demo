<%- include('../layouts/header') %>

<div class="container mt-5">
  <h2 class="mb-4">Duyệt giảng viên</h2>

  <% if (!users || users.length === 0) { %>
    <p>Không có yêu cầu nào.</p>
  <% } else { %>

    <table class="table table-bordered">
      <thead>
        <tr>
          <th>ID</th>
          <th>Họ tên</th>
          <th>Email</th>
          <th>Hành động</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(u => { %>
          <tr>
            <td><%= u.id %></td>
            <td><%= u.fullname %></td>
            <td><%= u.email %></td>
            <td>
              <a href="/admin/approve-teacher/<%= u.id %>" 
                 class="btn btn-success btn-sm">
                Duyệt
              </a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>

  <% } %>
</div>

<%- include('../layouts/footer') %>
