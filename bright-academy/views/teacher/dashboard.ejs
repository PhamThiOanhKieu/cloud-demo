<%- include('../layouts/header') %>

<div class="page">

    <div class="dashboard">

        <!-- SIDEBAR -->
        <div class="sidebar">

            <h4>Bright Academy</h4>

            <div class="menu">

                <a href="/teacher/dashboard" class="active">
                    <i class="fa fa-chart-line"></i>
                    Dashboard
                </a>

                <a href="/teacher/my-courses">
                    <i class="fa fa-book"></i>
                    Khóa học của tôi
                </a>


                <a href="/teacher/students">
                    <i class="fa fa-users"></i>
                    Học viên
                </a>

                <a href="/teacher/revenue">
                    <i class="fa fa-money-bill"></i>
                    Doanh thu
                </a>

                <a href="/logout" class="logout">
                    <i class="fa fa-sign-out-alt"></i>
                    Đăng xuất
                </a>

            </div>

        </div>

        <!-- CONTENT -->
        <div class="content">

            <div class="topbar">
                <h3>Xin chào giảng viên <%= user.fullname %></h3>

                <a href="/teacher/create-course" class="btn btn-primary">
                    + Tạo khóa học
                </a>
            </div>

<div class="row">

    <div class="col-md-4">
        <div class="card-box">
            <h5>Tổng khóa học</h5>
            <h2><%= totalCourses %></h2>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card-box">
            <h5>Học viên</h5>
            <h2><%= totalStudents %></h2>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card-box">
            <h5>Doanh thu</h5>
            <h2><%= totalRevenue %>đ</h2>
        </div>
    </div>

</div>
            <div class="card-box mt-4">

                <h4>Khóa học gần đây</h4>

                <table class="table mt-3">

                    <tr>
                        <th>Khóa học</th>
                        <th>Học viên</th>
                        <th>Doanh thu</th>
                    </tr>

                    <tr>
                        <td>AWS Cloud</td>
                        <td>320</td>
                        <td>12.000.000đ</td>
                    </tr>

                    <tr>
                        <td>Docker Master</td>
                        <td>180</td>
                        <td>7.500.000đ</td>
                    </tr>

                </table>

            </div>

        </div>

    </div>

    <%- include('../layouts/footer') %>

</div>
