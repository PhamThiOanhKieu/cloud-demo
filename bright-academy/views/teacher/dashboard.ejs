<%- include('../layouts/header') %>

<h1>Teacher Dashboard</h1>
<div class="dashboard-grid">

    <div class="card">
        <h2>My Courses</h2>
        <h3>10</h3>
    </div>

    <div class="card">
        <h2>Total Students</h2>
        <h3>350</h3>
    </div>

</div>

<h2>Khóa học của tôi</h2>

<% courses.forEach(c => { %>
  <div>
    <h4><%= c.title %></h4>
    <p>Trạng thái: <%= c.status %></p>
  </div>
<% }) %>
<%- include('../layouts/footer') %>
