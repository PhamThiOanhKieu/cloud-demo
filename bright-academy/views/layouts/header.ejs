<!DOCTYPE html>
<html lang="vi">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Bright Academy</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

    <link rel="stylesheet" href="/css/style.css">

</head>

<body class="d-flex flex-column min-vh-100">

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm py-3">

        <div class="container-fluid px-4">

            <a class="navbar-brand fw-bold fs-3" href="/">

                Bright Academy

            </a>

            <form class="d-flex ms-3 me-auto" style="flex-grow: 1; max-width: 500px;">
                <input class="form-control rounded-pill" type="search" placeholder="Tìm kiếm khóa học...">

            </form>

            <% if(user && user.role==='admin' ){ %>

                <div class="dropdown ms-auto">

                    <button class="btn btn-warning dropdown-toggle" data-bs-toggle="dropdown">

                        Admin Panel

                    </button>

                    <ul class="dropdown-menu dropdown-menu-end">

                        <li>
                            <a class="dropdown-item" href="/admin">
                                Dashboard
                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item" href="/admin/courses">
                                Quản lý khóa học
                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item" href="/admin/users">
                                Quản lý người dùng
                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item" href="/admin/teachers">
                                Quản lý giảng viên
                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item" href="/admin/orders">
                                Quản lý đơn hàng
                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item" href="/admin/certificates">
                                Quản lý chứng chỉ
                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item" href="/admin/revenue">
                                Quản lý doanh thu
                            </a>
                        </li>

                        <a class="dropdown-item" href="/admin/teacher-approval">
                            Duyệt giảng viên
                        </a>

                        <li>
                            <a class="dropdown-item text-danger" href="/logout">
                                Đăng xuất
                            </a>
                        </li>

                    </ul>

                </div>

                <% } else { %>

                 <div class="d-flex align-items-center gap-3 ms-auto">
                        <a href="/teacher/become-teacher" class="text-white text-decoration-none">
                            Giảng dạy trên Bright Academy
                        </a>

                        <a href="/cart" class="text-white">
                            <i class="fa-solid fa-cart-shopping"></i>
                        </a>

                        <a href="/notifications" class="text-white">
                            <i class="fa-solid fa-bell"></i>
                        </a>

                        <% if(user){ %>

                            <div class="dropdown">

                                <button class="btn btn-light dropdown-toggle rounded-pill" data-bs-toggle="dropdown">

                                    <%= user.fullname %>

                                </button>

                                <ul class="dropdown-menu dropdown-menu-end">

                                    <li>
                                        <a class="dropdown-item" href="/profile">
                                            Hồ sơ cá nhân
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item" href="/my-learning">
                                            Khóa học của tôi
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item" href="/my-orders">
                                            Lịch sử mua hàng
                                        </a>
                                    </li>

                                    <% if(user.role==='teacher' ){ %>

                                        <li>
                                            <a class="dropdown-item" href="/teacher">
                                                Teacher Dashboard
                                            </a>
                                        </li>

                                        <% } %>

                                            <li>
                                                <a class="dropdown-item text-danger" href="/logout">
                                                    Đăng xuất
                                                </a>
                                            </li>

                                </ul>

                            </div>

                            <% } else { %>

                                <a href="/login" class="btn btn-light rounded-pill px-4">
                                    Login
                                </a>

                                <a href="/register" class="btn btn-warning rounded-pill px-4">
                                    Register
                                </a>

                                <% } %>

                    </div>

                    <% } %>

        </div>

    </nav>

    <div class="flex-grow-1">
