<%- include('../layouts/header') %>

<div class="container mt-5">
  <h2 class="mb-4">Đăng ký trở thành giảng viên</h2>

  <form method="POST">

    <!-- CÂU 1 -->
    <div class="mb-4">
      <h5>Bạn đã từng giảng dạy chưa?</h5>

      <div>
        <input type="radio" name="teaching_exp" value="non-formal"> Trực tiếp, không chính thức
      </div>
      <div>
        <input type="radio" name="teaching_exp" value="professional"> Trực tiếp, chuyên nghiệp
      </div>
      <div>
        <input type="radio" name="teaching_exp" value="online"> Online
      </div>
      <div>
        <input type="radio" name="teaching_exp" value="other"> Khác
      </div>
    </div>

    <!-- CÂU 2 -->
    <div class="mb-4">
      <h5>Bạn sản xuất video ở mức độ nào?</h5>

      <div>
        <input type="radio" name="video_exp" value="beginner"> Tôi là người mới
      </div>
      <div>
        <input type="radio" name="video_exp" value="basic"> Tôi có một chút kiến thức
      </div>
      <div>
        <input type="radio" name="video_exp" value="experienced"> Tôi có kinh nghiệm
      </div>
      <div>
        <input type="radio" name="video_exp" value="ready"> Tôi có video sẵn sàng
      </div>
    </div>

    <!-- CÂU 3 -->
    <div class="mb-4">
      <h5>Bạn có đối tượng người học không?</h5>

      <div>
        <input type="radio" name="audience" value="none"> Không có
      </div>
      <div>
        <input type="radio" name="audience" value="small"> Có một ít người theo dõi
      </div>
      <div>
        <input type="radio" name="audience" value="large"> Có lượng lớn người theo dõi
      </div>
    </div>

    <!-- SUBMIT -->
    <button class="btn btn-primary">
      Gửi yêu cầu
    </button>

  </form>
</div>

<%- include('../layouts/footer') %>
