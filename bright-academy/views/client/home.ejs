
<%- include('../layouts/header') %>

<div class="container mt-5 mb-5">
  <!-- ===== BANNER ===== -->
  <div class="p-5 bg-primary text-white rounded mb-5">
    <h1 class="display-5 fw-bold">Bright Academy</h1>
    <p class="lead">Nền tảng học online chuyên nghiệp</p>
  </div>

  <!-- ===== DANH SÁCH KHÓA HỌC ===== -->
  <h3 class="mb-4 fw-bold">Khóa học nổi bật</h3>

  <% if (!courses || courses.length === 0) { %>
    <p>Chưa có khóa học nào</p>
  <% } else { %>

    <div class="row">

      <% courses.forEach(course => { %>

        <div class="col-md-3">
          <div class="card mb-4 shadow-sm h-100">

            <!-- ẢNH -->
            <img 
              src="<%= course.thumbnail 
                        ? (course.thumbnail.startsWith('http') 
                            ? course.thumbnail 
                            : '/uploads/' + course.thumbnail) 
                        : '/uploads/default.jpg' %>" 
              onerror="this.src='/uploads/default.jpg'"
              class="card-img-top"
              style="height:180px; object-fit:cover;"
            >

            <div class="card-body d-flex flex-column">

              <!-- TÊN KHÓA HỌC -->
              <h6 class="fw-bold">
                <%= course.title %>
              </h6>

              <!-- GIẢNG VIÊN -->
              <p class="text-muted mb-1">
                Giảng viên: <%= course.teacher_name || 'Chưa cập nhật' %>
              </p>

              <!-- GIÁ -->
              <p class="text-danger fw-bold mt-auto">
                <%= Number(course.price).toLocaleString('vi-VN') %> VNĐ
              </p>

              <!-- BUTTON -->
              <a href="/course/<%= course.id %>" class="btn btn-primary btn-sm w-100">
                Xem chi tiết
              </a>

              <!-- ADD CART -->
              <form action="/cart/add/<%= course.id %>" method="POST" class="mt-2">
                <button class="btn btn-success btn-sm w-100">
                  Thêm vào giỏ
                </button>
              </form>

            </div>

          </div>
        </div>

      <% }) %>

    </div>

  <% } %>

</div>

<!-- ===== CSS CHO ĐẸP ===== -->
<style>
  .card:hover {
    transform: translateY(-5px);
    transition: 0.3s;
  }
</style>

<%- include('../layouts/footer') %>
